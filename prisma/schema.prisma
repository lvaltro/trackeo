model InstallationJob {
  id               String    @id @default(uuid()) @db.Uuid
  installerId      String    @map("installer_id") @db.Uuid
  deviceId         String    @map("device_id") @db.Uuid
  vehicleId        String?   @map("vehicle_id") @db.Uuid
  organizationId   String?   @map("organization_id") @db.Uuid
  scheduledAt      DateTime? @map("scheduled_at")
  address          String?   @db.VarChar(500)
  contactName      String?   @map("contact_name") @db.VarChar(100)
  contactPhone     String?   @map("contact_phone") @db.VarChar(50)
  notes            String?   @db.Text
  status           String    @default("pending") @db.VarChar(20)
  completedAt      DateTime? @map("completed_at")
  durationMin      Int?      @map("duration_min")
  installPhotos    Json      @default("[]") @map("install_photos")
  installNotes     String?   @map("install_notes") @db.Text
