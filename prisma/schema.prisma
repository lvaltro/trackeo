model Subscription {
  id                 String    @id @default(uuid()) @db.Uuid
  organizationId     String    @map("organization_id") @db.Uuid
  planId             String    @map("plan_id") @db.Uuid
  countryId          String    @map("country_id") @db.Uuid
  status             String    @default("trialing") @db.VarChar(20)
  currentPeriodStart DateTime  @map("current_period_start")
  currentPeriodEnd   DateTime  @map("current_period_end")
  cancelAtPeriodEnd  Boolean   @default(false) @map("cancel_at_period_end")
  cancelledAt        DateTime? @map("cancelled_at")
  paymentProvider    String?   @map("payment_provider") @db.VarChar(30)
  externalId         String?   @map("external_id") @db.VarChar(255)
  amount             Decimal   @db.Decimal(12, 2)
  currency           String    @db.Char(3)
  billingCycle       String    @default("monthly") @map("billing_cycle") @db.VarChar(20)
  discountCode       String?   @map("discount_code") @db.VarChar(50)
  discountPercent    Decimal   @default(0) @map("discount_percent") @db.Decimal(5, 2)
  metadata           Json      @default("{}")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  plan         Plan         @relation(fields: [planId], references: [id])
  country      Country      @relation(fields: [countryId], references: [id])
  payments     Payment[]

  @@map("subscriptions")
}

model Payment {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  subscriptionId  String?   @map("subscription_id") @db.Uuid
  countryId       String    @map("country_id") @db.Uuid
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @db.Char(3)
  taxAmount       Decimal   @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount     Decimal   @map("total_amount") @db.Decimal(12, 2)
  status          String    @default("pending") @db.VarChar(20)
  paymentMethod   String?   @map("payment_method") @db.VarChar(50)
  paymentProvider String?   @map("payment_provider") @db.VarChar(30)
  externalId      String?   @map("external_id") @db.VarChar(255)
  failureReason   String?   @map("failure_reason") @db.Text
  invoiceUrl      String?   @map("invoice_url") @db.VarChar(500)
  invoiceNumber   String?   @map("invoice_number") @db.VarChar(100)
  paidAt          DateTime? @map("paid_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  country      Country       @relation(fields: [countryId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@map("payments")
}

